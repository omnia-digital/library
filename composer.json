{
    "name": "omnia-digital/library",
    "description": "A comprehensive Laravel Livewire component library with UI components, traits, and third-party integrations",
    "keywords": [
        "omnia-digital",
        "laravel",
        "library",
        "livewire",
        "components",
        "blade",
        "tiptap",
        "stripe",
        "mapbox"
    ],
    "homepage": "https://github.com/omnia-digital/library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omnia Church Apps",
            "email": "info@omnia.church",
            "homepage": "https://omnia.church"
        }
    ],
    "require": {
        "php": "^8.2",
        "codeat3/blade-coolicons": "^1.2||^2.0",
        "illuminate/contracts": "^10.0 || ^11.0",
        "livewire/livewire": "^2.10||^3.0",
        "spatie/laravel-package-tools": "^1.9.2"
    },
    "require-dev": {
        "nunomaduro/collision": "^7.0||^8.0",
        "orchestra/testbench": "^8.0||^9.0",
        "pestphp/pest": "^2.0||^3.0",
        "pestphp/pest-plugin-laravel": "^2.0||^3.0",
        "phpunit/phpunit": "^10.0||^11.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "OmniaDigital\\OmniaLibrary\\": "src",
            "OmniaDigital\\OmniaLibrary\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OmniaDigital\\OmniaLibrary\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OmniaDigital\\OmniaLibrary\\OmniaLibraryServiceProvider"
            ],
            "aliases": {
                "OmniaLibrary": "OmniaDigital\\OmniaLibrary\\Facades\\OmniaLibrary"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
